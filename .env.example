# ─── Gade AMS — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=gade_ams
POSTGRES_USER=gade_ams_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ─── JWT & Session ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_byte_hex_secret
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── File Encryption ─────────────────────────────────────────────────────────
# AES-256-GCM master key — generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_byte_hex_key

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=25

# ─── Hosting ─────────────────────────────────────────────────────────────────
DOMAIN=ams.gadeassociates.co.ke
CERTBOT_EMAIL=kichakuri@gadeassociates.co.ke

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=production
